#!/usr/bin/env bash
set -euo pipefail
oci() {
  docker run --rm -i \
    -e "OCI_CLI_SUPPRESS_FILE_PERMISSIONS_WARNING=True" \
    -v "$HOME/.oci:/oracle/.oci" oci "$@"
}

REGION="${1:-}"

if [[ -z "$REGION" ]]; then
  echo "Usage: source $0 <oci-region>"
  echo "Example: source $0 ap-singapore-1"
  return 1 2>/dev/null || exit 1
fi

BASHRC="${HOME}/.bashrc"
OCI_CONFIG="${HOME}/.oci/config"
OCI_PROFILE="${OCI_PROFILE:-DEFAULT}"

BEGIN_MARK="# >>> OCI REGION ENV BEGIN"
END_MARK="# <<< OCI REGION ENV END"

echo "Switching OCI region to: ${REGION}"

if ! command -v oci >/dev/null 2>&1; then
  echo "ERROR: oci CLI not found."
  return 1 2>/dev/null || exit 1
fi

if [[ ! -f "$OCI_CONFIG" ]]; then
  echo "ERROR: OCI config not found: $OCI_CONFIG"
  return 1 2>/dev/null || exit 1
fi

touch "$BASHRC"

# 备份 .bashrc
cp "$BASHRC" "${BASHRC}.bak.$(date +%Y%m%d%H%M%S)"

# 修改 OCI CLI config 中的 region
if grep -q "^region=" "$OCI_CONFIG"; then
  sed -i.bak "s|^region=.*|region=${REGION}|g" "$OCI_CONFIG"
else
  echo "region=${REGION}" >> "$OCI_CONFIG"
fi

TENANCY_ID="$(awk -F= '
  $1=="tenancy" {gsub(/[[:space:]]/, "", $2); print $2}
' "$OCI_CONFIG" | head -n1)"

USER_ID="$(awk -F= '
  $1=="user" {gsub(/[[:space:]]/, "", $2); print $2}
' "$OCI_CONFIG" | head -n1)"

if [[ -z "$TENANCY_ID" ]]; then
  echo "ERROR: Could not determine tenancy OCID."
  return 1 2>/dev/null || exit 1
fi

if [[ -z "$USER_ID" ]]; then
  echo "ERROR: Could not determine user OCID."
  return 1 2>/dev/null || exit 1
fi

# 检查目标区域是否已订阅
SUBSCRIBED_REGION="$(oci iam region-subscription list \
  --profile "$OCI_PROFILE" \
  --query "data[?\"region-name\"=='${REGION}'].\"region-name\" | [0]" \
  --raw-output)"

if [[ "$SUBSCRIBED_REGION" != "$REGION" ]]; then
  echo "ERROR: Tenancy is not subscribed to region: ${REGION}"
  echo "Subscribed regions:"
  oci iam region-subscription list \
    --profile "$OCI_PROFILE" \
    --query 'data[]."region-name"' \
    --output table
  return 1 2>/dev/null || exit 1
fi

# 默认取第一个 ACTIVE compartment
COMPARTMENT_ID="$(oci iam compartment list \
  --profile "$OCI_PROFILE" \
  --compartment-id "$TENANCY_ID" \
  --compartment-id-in-subtree true \
  --access-level ACCESSIBLE \
  --lifecycle-state ACTIVE \
  --query 'data[0].id' \
  --raw-output 2>/dev/null || true)"

if [[ -z "$COMPARTMENT_ID" || "$COMPARTMENT_ID" == "null" ]]; then
  COMPARTMENT_ID="$TENANCY_ID"
fi

AD_NAME="$(oci iam availability-domain list \
  --profile "$OCI_PROFILE" \
  --compartment-id "$TENANCY_ID" \
  --query 'data[0].name' \
  --raw-output)"

VCN_ID="$(oci network vcn list \
  --profile "$OCI_PROFILE" \
  --compartment-id "$COMPARTMENT_ID" \
  --lifecycle-state AVAILABLE \
  --query 'data[0].id' \
  --raw-output 2>/dev/null || true)"

if [[ "$VCN_ID" == "null" ]]; then
  VCN_ID=""
fi

SUBNET_ID=""
SECURITY_LIST_ID=""

if [[ -n "$VCN_ID" ]]; then
  SUBNET_ID="$(oci network subnet list \
    --profile "$OCI_PROFILE" \
    --compartment-id "$COMPARTMENT_ID" \
    --vcn-id "$VCN_ID" \
    --lifecycle-state AVAILABLE \
    --query 'data[0].id' \
    --raw-output 2>/dev/null || true)"

  SECURITY_LIST_ID="$(oci network security-list list \
    --profile "$OCI_PROFILE" \
    --compartment-id "$COMPARTMENT_ID" \
    --vcn-id "$VCN_ID" \
    --lifecycle-state AVAILABLE \
    --query 'data[0].id' \
    --raw-output 2>/dev/null || true)"
fi

if [[ "$SUBNET_ID" == "null" ]]; then
  SUBNET_ID=""
fi

if [[ "$SECURITY_LIST_ID" == "null" ]]; then
  SECURITY_LIST_ID=""
fi

# 生成新的环境变量块
NEW_BLOCK="$(cat <<EOF
${BEGIN_MARK}
# Auto generated by switch_oci_region.sh
# Last region: ${REGION}

export OCI_REGION="${REGION}"
export T="${TENANCY_ID}"
export U="${USER_ID}"
export C="${COMPARTMENT_ID}"
export AD="${AD_NAME}"
export VC="${VCN_ID}"
export SI="${SUBNET_ID}"
export SL="${SECURITY_LIST_ID}"
${END_MARK}
EOF
)"

# 删除 .bashrc 里旧的 OCI 环境变量块
if grep -q "$BEGIN_MARK" "$BASHRC"; then
  awk -v begin="$BEGIN_MARK" -v end="$END_MARK" '
    $0 == begin {skip=1; next}
    $0 == end {skip=0; next}
    skip != 1 {print}
  ' "$BASHRC" > "${BASHRC}.tmp"

  mv "${BASHRC}.tmp" "$BASHRC"
fi

# 追加新的 OCI 环境变量块到 .bashrc
{
  echo
  echo "$NEW_BLOCK"
} >> "$BASHRC"

# 让当前 shell 立即生效
export OCI_REGION="${REGION}"
export T="${TENANCY_ID}"
export U="${USER_ID}"
export C="${COMPARTMENT_ID}"
export AD="${AD_NAME}"
export VC="${VCN_ID}"
export SI="${SUBNET_ID}"
export SL="${SECURITY_LIST_ID}"

echo
echo "OCI region switched successfully."
echo "Updated: ${BASHRC}"
echo
echo "Current values:"
echo "  OCI_REGION = ${OCI_REGION}"
echo "  T          = ${T}"
echo "  U          = ${U}"
echo "  C          = ${C}"
echo "  AD         = ${AD}"
echo "  VC         = ${VC}"
echo "  SI         = ${SI}"
echo "  SL         = ${SL}"
echo
echo "For new shells, variables will be loaded from ~/.bashrc automatically."
echo "For current shell, this script has already exported them if you used source."
